    "initialPermissionMode": "acceptEdits",
    "cleanupPeriodDays": 30,
    "autoUpdaterStatus": "enabled"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE_PATH=\"$CLAUDE_FILE_PATH\"; if [[ \"$FILE_PATH\" == *.env && \"$FILE_PATH\" != *.env.example ]]; then echo \"⚠️ 检测到 .env 文件修改请求: $FILE_PATH\"; echo \"敏感配置文件需要手动确认，请输入 y 确认\"; read -t 30 confirm; if [[ \"$confirm\" != \"y\" ]]; then echo \"已取消操作\"; exit 1; fi; fi'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE_PATH=\"$CLAUDE_FILE_PATH\"; if [[ \"$FILE_PATH\" == *pnpm-lock.yaml || \"$FILE_PATH\" == *package-lock.json ]]; then echo \"⚠️ 检测到 lock 文件修改请求: $FILE_PATH\"; echo \"Lock 文件应由包管理器自动生成，请输入 y 确认\"; read -t 30 confirm; if [[ \"$confirm\" != \"y\" ]]; then exit 1; fi; fi'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE_PATH=\"$CLAUDE_FILE_PATH\"; if [[ \"$FILE_PATH\" == backend/src/*.ts || \"$FILE_PATH\" == backend/src/**/*.ts ]]; then echo \"🔍 TypeScript 类型检查...\"; cd backend && pnpm exec tsc --noEmit 2>&1 | head -20 || true; fi'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE_PATH=\"$CLAUDE_FILE_PATH\"; if [[ \"$FILE_PATH\" == frontend/apps/web-antd/src/**/*.ts || \"$FILE_PATH\" == frontend/apps/web-antd/src/**/*.vue ]]; then echo \"🔍 oxlint 检查...\"; cd frontend && pnpm exec oxlint \"$FILE_PATH\" 2>&1 | head -20 || true; fi'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE_PATH=\"$CLAUDE_FILE_PATH\"; if [[ \"$FILE_PATH\" == *.test.ts || \"$FILE_PATH\" == *.spec.ts ]]; then echo \"🧪 运行相关测试...\"; cd frontend && pnpm vitest run \"$FILE_PATH\" 2>&1 | tail -30 || true; fi'"
          }
        ]
      }
    ]
  }
}
