    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "bull": "^4.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fluent-ffmpeg": "^2.1.2",
    "heic-convert": "^2.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.2",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
