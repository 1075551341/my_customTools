{
  "name": "my-customtools-backend",
  "version": "1.0.0",
  "description": "统一后端服务 - 视频转码 & 图片转码工具集",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ffmpeg",
    "transcode",
    "video",
    "image"
  ],
  "author": "",
  "license": "MIT",
