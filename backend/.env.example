# ==========================================
# backend/.env.example
# ==========================================
# 复制本文件为 .env，按实际情况修改值

# 服务配置
PORT=3001
NODE_ENV=development

# JWT 配置（生产环境必须修改！）
JWT_SECRET=change-me-please-xxx
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Redis 配置（Bull 队列依赖 Redis）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# 存储路径（相对路径或绝对路径均可）
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
DATA_DIR=./data
LOG_DIR=./logs

# 功能开关
ALLOW_REGISTER=true
ENABLE_RATE_LIMIT=true

# FFmpeg 配置
FFMPEG_PATH=
FFPROBE_PATH=

# CORS 配置（允许哪些前端域名访问，逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# 前端访问地址（用于生成文件访问 URL）
BASE_URL=http://localhost:3001